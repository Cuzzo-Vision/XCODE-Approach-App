rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
    }
    
    // Membership payments (Stripe relay)
    match /membership_payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.email == request.auth.token.email || resource.data.userId == request.auth.uid);
    }

    // Gift payments (Stripe relay)
    match /gift_payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.email == request.auth.token.email || resource.data.userId == request.auth.uid);
    }
    
    // Gifts collection
    match /gifts/{giftId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }
    
    // Approaches/Interactions
    match /approaches/{approachId} {
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
    }
  }
}
